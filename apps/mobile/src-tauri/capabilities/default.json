{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-has",
    "store:allow-keys",
    "store:allow-save",
    "dialog:allow-open",
    "dialog:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" }
      ]
    },
    {
      "identifier": "http:allow-fetch-send",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" }
      ]
    },
    {
      "identifier": "http:allow-fetch-read-body",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" }
      ]
    }
  ]
}
