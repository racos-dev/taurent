{
  "name": "taurent",
  "private": true,
  "version": "1.0.0",
  "author": "racos.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/racos-dev/taurent.git",
    "directory": "apps/desktop"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node scripts/dev/tauri-dev.mjs",
    "tauri:build": "tauri build",
    "icons:check": "node scripts/icons/sync-tray-rgba.mjs",
    "icons:sync": "node scripts/icons/sync-tray-rgba.mjs --write",
    "analyze": "cross-env VITE_ANALYZE=1 VITE_SOURCEMAP=1 pnpm build",
    "perf:baseline": "tsx scripts/perf/write-baseline.ts",
    "perf:compare": "tsx scripts/perf/compare-baseline.ts",
    "perf:check": "tsx scripts/perf/check-bundle.ts",
    "perf": "pnpm analyze && pnpm build && pnpm perf:check && pnpm perf:compare",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled",
    "test:watch": "vitest",
    "test:browser": "vitest --browser chromium --run",
    "test:browser:coverage": "vitest --browser chromium --run --coverage.enabled",
    "renderer:e2e": "playwright test -c playwright.config.ts --project=chromium",
    "renderer:e2e:ui": "playwright test --ui -c playwright.config.ts",
    "e2e": "pnpm renderer:e2e",
    "e2e:ui": "pnpm renderer:e2e:ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.7",
    "@taurent/bridge": "workspace:*",
    "@taurent/shared": "workspace:*",
    "@taurent/web-core": "workspace:*",
    "@taurent/web-ui": "workspace:*",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.4",
    "vitest": "4.1.9"
  }
}
